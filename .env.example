# Powder Hunter Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Load before running:
#   source .env

# Gemini API key — get from https://aistudio.google.com/apikey
# Required for: powder-hunter run, powder-hunter replay, Gemini smoke tests
GOOGLE_API_KEY=your-gemini-api-key-here

# Discord webhook URL — create in Server Settings → Integrations → Webhooks
# Point it at a Forum Channel (not a regular text channel)
# Required for: powder-hunter run (unless --dry-run), Discord smoke tests
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Smoke test toggle — set to 1 to run smoke tests against real APIs
SMOKE_TEST=1
